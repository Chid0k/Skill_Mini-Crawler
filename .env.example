# ─────────────────────────────────────────────────────────────────────────────
# Browserless Crawler — Environment Variables
# Copy this file to .env and fill in any values you need.
# None of these are required; they all have sensible defaults.
# ─────────────────────────────────────────────────────────────────────────────

# Path to Chromium/Chrome binary.
# Set this when you want to use a system-installed browser instead of the
# Puppeteer-bundled Chromium (required in Docker if PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true).
# Example (Linux):  /usr/bin/chromium
# Example (macOS):  /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# PUPPETEER_EXECUTABLE_PATH=

# Skip downloading Chromium during `npm install`.
# Useful for Docker images that install Chromium via apt instead.
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# Browserless WebSocket endpoint — use this instead of a local browser.
# Equivalent to passing --browserless <endpoint> on the CLI.
# Example (local docker-compose):  ws://localhost:3000
# Example (hosted):                wss://chrome.browserless.io?token=YOUR_TOKEN
# BROWSERLESS_ENDPOINT=

# ─────────────────────────────────────────────────────────────────────────────
# NOTE: The crawler is CLI-driven.  Variables above are read by Puppeteer
# automatically; BROWSERLESS_ENDPOINT is documented here for reference but
# must currently be passed via the --browserless flag or set in a wrapper.
# ─────────────────────────────────────────────────────────────────────────────
